{
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
  "python.terminal.activateEnvironment": false,
  "python.terminal.shellIntegration.enabled": false,
  "terminal.integrated.defaultProfile.linux": "BPM (.venv)",
  "terminal.integrated.profiles.linux": {
    "BPM (.venv)": {
      "path": "/bin/bash",
      "args": [
        "--rcfile",
        "${workspaceFolder}/.vscode/terminal-bpm.bashrc"
      ]
    }
  },
  "terminal.integrated.cwd": "${workspaceFolder}",
  "terminal.integrated.enablePersistentSessions": false,
  "terminal.integrated.persistentSessionReviveProcess": "never",
  "terminal.integrated.environmentChangesRelaunch": false,
  "terminal.integrated.shellIntegration.enabled": false,
  "python.analysis.extraPaths": [
    "${workspaceFolder}"
  ],
  "python.testing.pytestEnabled": true,
  "python.testing.unittestEnabled": false,
  "python.testing.pytestArgs": [
    "tests"
  ],
  "isort.importStrategy": "fromEnvironment",
  "isort.interpreter": [
    "${workspaceFolder}/.venv/bin/python"
  ],
  "ruff.importStrategy": "fromEnvironment",
  "ruff.interpreter": [
    "${workspaceFolder}/.venv/bin/python"
  ],
  "editor.formatOnSave": true,
  "python.analysis.autoImportCompletions": true,
  "gitlens.gitkraken.cli.integration.enabled": false,
  "gitlens.gitkraken.cli.insiders.enabled": false,
  "files.associations": {
    "*.html": "jinja-html",
    "*.jinja": "jinja-html",
    "*.jinja2": "jinja-html"
  },
  "chat.tools.terminal.autoApprove": {
    "/^pytest -q$/": {
      "approve": true,
      "matchCommandLine": true
    },
    "pytest": true
  }
}
